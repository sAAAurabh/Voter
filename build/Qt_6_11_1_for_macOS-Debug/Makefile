voter.app/Contents/PkgInfo: 
	@test -d voter.app/Contents || mkdir -p voter.app/Contents
	@$(DEL_FILE) voter.app/Contents/PkgInfo
	@echo "APPL????" > voter.app/Contents/PkgInfo
voter.app/Contents/Info.plist: 
	@test -d voter.app/Contents || mkdir -p voter.app/Contents
	@$(DEL_FILE) voter.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - ../../../Qt/6.11.1/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.voter,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.voter,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,voter,g" -e "s,@LIBRARY@,voter,g" -e "s,\$${EXECUTABLE_NAME},voter,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >voter.app/Contents/Info.plist

all: Makefile \
		voter.app/Contents/PkgInfo \
		voter.app/Contents/Info.plist voter.app/Contents/MacOS/voter

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../admin.h ../../candidate.h ../../candidate_home.h ../../candidate_login_window.h ../../candidate_register_window.h ../../database.h ../../picosh.h ../../voter.h ../../voter_home.h ../../voter_login_window.h ../../voter_register_window.h ../../voting_page.h ../../widget.h ../../manifesto_edit_window.h ../../view_candidates_window.h $(DISTDIR)/
	$(COPY_FILE) --parents ../../admin.cpp ../../candidate.cpp ../../candidate_home.cpp ../../candidate_login_window.cpp ../../candidate_register_window.cpp ../../database.cpp ../../main.cpp ../../voter.cpp ../../voter_home.cpp ../../voter_login_window.cpp ../../voter_register_window.cpp ../../voting_page.cpp ../../widget.cpp ../../manifesto_edit_window.cpp ../../view_candidates_window.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../widget.ui $(DISTDIR)/


