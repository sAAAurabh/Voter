####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/voter/bin || mkdir -p $(INSTALL_ROOT)/opt/voter/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/voter/bin/voter.app
	
	$(QINSTALL) voter.app $(INSTALL_ROOT)/opt/voter/bin/voter.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/voter/bin/voter.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/voter/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

